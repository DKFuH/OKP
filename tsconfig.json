{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
      "@yakds/shared-schemas": [
        "shared-schemas/src/index.ts"
      ],
      "@yakds/dxf-import": [
        "interop-cad/dxf-import/src/index.ts"
      ],
      "@yakds/dxf-export": [
        "interop-cad/dxf-export/src/index.ts"
      ],
      "@yakds/skp-import": [
        "interop-sketchup/skp-import/src/index.ts"
      ],
      "@shared/*": [
        "shared-schemas/src/*"
      ],
      "@planner-api/*": [
        "planner-api/src/*"
      ],
      "@planner-frontend/*": [
        "planner-frontend/src/*"
      ],
      "@dxf-import/*": [
        "interop-cad/dxf-import/src/*"
      ],
      "@dxf-export/*": [
        "interop-cad/dxf-export/src/*"
      ],
      "@skp-import/*": [
        "interop-sketchup/skp-import/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.d.ts"
  ]
}
